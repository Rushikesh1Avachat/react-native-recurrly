{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.19.4",
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=8192"
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "20.19.4",
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=8192"
      }
    },
    "production": {
      "node": "20.19.4",
      "autoIncrement": true,
      "cache": {
        "clear": true
      },
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=8192"
      }
    }
  }
}